            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>

                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>

                <data android:scheme="https" android:host="www.furaffinity.net" android:pathPrefix="/view/"/>
                <data android:scheme="https" android:host="www.furaffinity.net" android:pathPrefix="/journal/"/>
                <data android:scheme="https" android:host="www.furaffinity.net" android:pathPrefix="/gallery/"/>
                <data android:scheme="https" android:host="www.furaffinity.net" android:pathPrefix="/favorites/"/>
                <data android:scheme="https" android:host="www.furaffinity.net" android:pathPrefix="/scraps/"/>
                <data android:scheme="https" android:host="www.furaffinity.net" android:pathPrefix="/journals/"/>
                <data android:scheme="https" android:host="www.furaffinity.net" android:pathPrefix="/user/"/>

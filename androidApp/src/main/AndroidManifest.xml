                <data android:scheme="https" android:host="furaffinity.net" android:pathPrefix="/journals/"/>
                <data android:scheme="https" android:host="furaffinity.net" android:pathPrefix="/user/"/>
                <data android:scheme="http" android:host="www.furaffinity.net" android:pathPrefix="/view/"/>
                <data android:scheme="http" android:host="www.furaffinity.net" android:pathPrefix="/journal/"/>
                <data android:scheme="http" android:host="www.furaffinity.net" android:pathPrefix="/gallery/"/>
